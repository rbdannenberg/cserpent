#include "cserpent.h"

#include "easyglobal.h"
#include "global_vars.h"
#include "data_structures/symbol.h"

int main() {
    runtime_init();  // Initialize runtime (needed for css_t and boolean support)

    cs_global_init();

    set_any_global(&csg_a, 1);
    set_any_global(&csg_b, 2);
    std::cout << (csg_a + csg_b) << std::endl;
    return 0;
}
// mark any global references to heap objects
void gc_mark_roots()
{
runtime_mark_roots();
}
